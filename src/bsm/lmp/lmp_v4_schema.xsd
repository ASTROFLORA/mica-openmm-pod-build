  <!-- TrajectoryIFP (MD Dynamics - SMIC Integration)                  -->
  <!-- ================================================================ -->

  <xs:complexType name="TrajectoryIFPType">
    <xs:sequence>
      <xs:element name="Frame" type="lmp:IFPFrameType" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="Summary" type="lmp:IFPSummaryType" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="pdb_id" type="xs:string" use="required"/>
    <xs:attribute name="ligand" type="xs:string" use="required">
      <xs:annotation>
        <xs:documentation>
          Ligand name or residue ID (e.g., "ATP", "ADP", "LIG", "UNK")
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="total_frames" type="xs:nonNegativeInteger" use="required"/>
    <xs:attribute name="time_step_ps" type="xs:float" use="optional">
      <xs:annotation>
        <xs:documentation>
          Time step in picoseconds between frames (e.g., 0.1, 1.0, 10.0)
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="stride" type="xs:positiveInteger" default="1">
      <xs:annotation>
        <xs:documentation>
          Frame stride (e.g., 1 = every frame, 10 = every 10th frame)
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="IFPFrameType">
    <xs:sequence>
      <xs:element name="Interaction" type="lmp:InteractionType" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="Fingerprint" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Bit-string representation of interactions (e.g., "1010010110...")
            Each bit corresponds to a predefined interaction type.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="number" type="xs:nonNegativeInteger" use="required"/>
    <xs:attribute name="time_ns" type="xs:float" use="optional">
      <xs:annotation>
        <xs:documentation>
          Simulation time in nanoseconds (e.g., 0.1, 1.5, 10.0)
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="InteractionType">
    <xs:attribute name="type" use="required">
      <xs:simpleType>
        <xs:restriction base="xs:string">
          <xs:enumeration value="H-Bond"/>
          <xs:enumeration value="Hydrophobic"/>
          <xs:enumeration value="Pi-Stacking"/>
          <xs:enumeration value="Pi-Cation"/>
          <xs:enumeration value="Salt-Bridge"/>
          <xs:enumeration value="Water-Bridge"/>
          <xs:enumeration value="Halogen-Bond"/>
          <xs:enumeration value="Metal-Coordination"/>
        </xs:restriction>
      </xs:simpleType>
    </xs:attribute>
    <xs:attribute name="residue" type="xs:string" use="required">
      <xs:annotation>
        <xs:documentation>
          Residue identifier (e.g., "ASP166", "TYR72", "LYS295")
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="ligand_atom" type="xs:string" use="optional">
      <xs:annotation>
        <xs:documentation>
          Ligand atom name (e.g., "O2", "N1", "C6")
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="distance" type="xs:float" use="optional">
      <xs:annotation>
        <xs:documentation>
          Distance in Ångströms (Å)
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="angle" type="xs:float" use="optional">
      <xs:annotation>
        <xs:documentation>
          Angle in degrees (for H-bonds: D-H-A angle; for pi-stacking: dihedral angle)
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="occupancy" type="xs:float" use="optional">
      <xs:annotation>
        <xs:documentation>
          Occupancy fraction (0.0-1.0) across trajectory
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="IFPSummaryType">
    <xs:sequence>
      <xs:element name="KeyInteraction" type="lmp:KeyInteractionType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="total_interactions" type="xs:nonNegativeInteger" use="optional"/>
    <xs:attribute name="average_interactions_per_frame" type="xs:float" use="optional"/>
  </xs:complexType>

  <xs:complexType name="KeyInteractionType">
    <xs:attribute name="residue" type="xs:string" use="required"/>
    <xs:attribute name="type" type="xs:string" use="required"/>
    <xs:attribute name="occupancy" type="xs:float" use="required">
      <xs:annotation>
        <xs:documentation>
          Occupancy across trajectory (0.0-1.0). High occupancy (>0.5) indicates persistent interaction.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="avg_distance" type="xs:float" use="optional"/>
    <xs:attribute name="avg_angle" type="xs:float" use="optional"/>
  </xs:complexType>

  <xs:simpleType name="ResidueListType">
    <xs:restriction base="xs:string">
